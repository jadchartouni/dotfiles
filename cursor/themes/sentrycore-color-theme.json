    "editorOverviewRuler.findMatchForeground": "#A855E0",
    "editorOverviewRuler.modifiedForeground": "#6BA8FF",
    "editorOverviewRuler.addedForeground": "#3DD5B6",
    "editorOverviewRuler.deletedForeground": "#E74C3C",
    "editorOverviewRuler.errorForeground": "#E74C3C",
    "editorOverviewRuler.warningForeground": "#C29BFF",
    "minimap.selectionHighlight": "#3D2570",
    "minimap.findMatchHighlight": "#A855E0",

    "//5": "─── Widgets (suggest / hover / peek) ───",
    "editorWidget.background": "#15102A",
    "editorWidget.border": "#2A2045",
    "editorWidget.foreground": "#E6E4F0",
    "editorSuggestWidget.background": "#15102A",
    "editorSuggestWidget.border": "#2A2045",
    "editorSuggestWidget.foreground": "#E6E4F0",
    "editorSuggestWidget.selectedBackground": "#2A1F4A",
    "editorSuggestWidget.highlightForeground": "#A855E0",
    "editorHoverWidget.background": "#15102A",
    "editorHoverWidget.border": "#2A2045",
    "peekView.border": "#6A39A9",
