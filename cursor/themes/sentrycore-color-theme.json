    "peekViewResult.matchHighlightBackground": "#6A39A980",
    "peekViewTitle.background": "#0A0618",
    "peekViewTitleLabel.foreground": "#E6E4F0",

    "//6": "─── Activity bar ───",
    "activityBar.background": "#0A0618",
    "activityBar.foreground": "#E6E4F0",
    "activityBar.inactiveForeground": "#5E5280",
    "activityBar.border": "#1A1230",
    "activityBarBadge.background": "#A855E0",
    "activityBarBadge.foreground": "#0F0A1F",
    "activityBar.activeBorder": "#A855E0",

    "//7": "─── Side bar ───",
