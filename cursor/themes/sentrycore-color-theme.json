{
  "name": "SentryCore",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "//": "─── Base ───",
    "foreground": "#E6E4F0",
    "focusBorder": "#6A39A9",
    "selection.background": "#3D2570",
    "descriptionForeground": "#9890B8",
    "errorForeground": "#E74C3C",
    "icon.foreground": "#9890B8",
    "widget.border": "#2A2045",
    "contrastBorder": "#00000000",

    "//1": "─── Editor ───",
    "editor.background": "#0F0A1F",
    "editor.foreground": "#E6E4F0",
    "editorLineNumber.foreground": "#3D3560",
    "editorLineNumber.activeForeground": "#9890B8",
    "editorCursor.foreground": "#A855E0",
    "editor.selectionBackground": "#3D2570",
    "editor.selectionHighlightBackground": "#2A1F4A",
    "editor.inactiveSelectionBackground": "#2A1F4A",
    "editor.wordHighlightBackground": "#2A1F4A",
    "editor.wordHighlightStrongBackground": "#3D2570",
    "editor.lineHighlightBackground": "#1A1230",
    "editor.lineHighlightBorder": "#00000000",
    "editor.findMatchBackground": "#6A39A9",
    "editor.findMatchHighlightBackground": "#3D257080",
    "editor.findRangeHighlightBackground": "#2A1F4A80",
    "editor.hoverHighlightBackground": "#2A1F4A",
    "editor.rangeHighlightBackground": "#1A1230",
    "editorWhitespace.foreground": "#2A2045",
    "editorIndentGuide.background1": "#2A2045",
    "editorIndentGuide.activeBackground1": "#3D3560",
    "editorRuler.foreground": "#2A2045",
    "editorBracketMatch.background": "#3D257080",
    "editorBracketMatch.border": "#A855E0",
    "editorCodeLens.foreground": "#5E5280",
    "editorLink.activeForeground": "#6BA8FF",

    "//2": "─── Bracket pair colors ───",
    "editorBracketHighlight.foreground1": "#A855E0",
    "editorBracketHighlight.foreground2": "#6BA8FF",
    "editorBracketHighlight.foreground3": "#3DD5B6",
    "editorBracketHighlight.foreground4": "#C29BFF",
    "editorBracketHighlight.foreground5": "#FF6B5B",
    "editorBracketHighlight.foreground6": "#5A78D9",
